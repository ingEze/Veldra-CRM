---
import Layout from '../../../layouts/Layout.astro'
---

<Layout title="Meeting Details">
  <div class="min-h-screen bg-[#fdfcf8]">
    <!-- Nav -->
    <div class="bg-[#fdfcf8] border-b border-[#eef2f7] sticky top-0 z-10">
      <div
        class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between"
      >
        <button
          id="btnBack"
          class="flex items-center gap-2 text-[13px] font-medium text-slate-500 hover:text-slate-900 transition-colors group"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="group-hover:-translate-x-1 transition-transform"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Back
        </button>
        <button
          id="btnDeleteMeeting"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[13px] font-medium text-red-400 hover:text-red-600 hover:bg-red-50 transition-all"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
            <path d="M10 11v6M14 11v6"></path>
            <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
          </svg>
          Delete
        </button>
      </div>
    </div>

    <!-- Loading skeleton -->
    <div id="loadingState" class="max-w-4xl mx-auto px-6 py-10 animate-pulse">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-14 h-14 bg-slate-200 rounded-2xl shrink-0"></div>
        <div class="flex-1">
          <div class="h-7 bg-slate-200 rounded w-1/2 mb-2"></div>
          <div class="h-4 bg-slate-200 rounded w-1/3"></div>
        </div>
        <div class="h-7 w-24 bg-slate-200 rounded-full"></div>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        {
          Array.from({ length: 4 }).map(() => (
            <div class="h-20 bg-slate-200 rounded-xl" />
          ))
        }
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-5">
          <div class="h-64 bg-slate-200 rounded-2xl"></div>
          <div class="h-48 bg-slate-200 rounded-2xl"></div>
        </div>
        <div class="space-y-4">
          <div class="h-44 bg-slate-200 rounded-2xl"></div>
          <div class="h-36 bg-slate-200 rounded-2xl"></div>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div id="mainContent" class="hidden max-w-4xl mx-auto px-6 py-8">
      <!-- Header -->
      <div
        class="mb-8 flex flex-col sm:flex-row sm:items-start justify-between gap-4"
      >
        <div class="flex items-center gap-4">
          <div
            id="meetingTypeBubble"
            class="w-14 h-14 rounded-2xl flex items-center justify-center shrink-0 shadow-sm"
          >
          </div>
          <div>
            <h1
              id="meetingTitle"
              class="font-serif text-[26px] sm:text-[30px] text-slate-900 tracking-tight leading-tight mb-1"
            >
            </h1>
            <a
              id="meetingClientLink"
              href="#"
              class="text-[13px] text-slate-500 font-medium hover:text-slate-800 transition-colors flex items-center gap-1.5"
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
              </svg>
              <span id="meetingClientName"></span>
            </a>
          </div>
        </div>
        <div
          id="statusBadge"
          class="self-start px-3.5 py-1.5 rounded-full text-[11px] font-bold uppercase tracking-wider shadow-sm border shrink-0"
        >
        </div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        <div class="bg-white rounded-xl p-4 border border-slate-200 shadow-sm">
          <p
            class="text-[11px] text-slate-400 uppercase tracking-wider font-bold mb-1.5"
          >
            Date
          </p>
          <p id="statDate" class="text-[13px] text-slate-800 font-medium">—</p>
        </div>
        <div class="bg-white rounded-xl p-4 border border-slate-200 shadow-sm">
          <p
            class="text-[11px] text-slate-400 uppercase tracking-wider font-bold mb-1.5"
          >
            Time
          </p>
          <p id="statTime" class="text-[13px] text-slate-800 font-medium">—</p>
        </div>
        <div class="bg-white rounded-xl p-4 border border-slate-200 shadow-sm">
          <p
            class="text-[11px] text-slate-400 uppercase tracking-wider font-bold mb-1.5"
          >
            Type
          </p>
          <p id="statType" class="text-[13px] text-slate-800 font-medium">—</p>
        </div>
        <div id="statCountdownCard" class="rounded-xl p-4 border shadow-sm">
          <p
            id="statCountdownLabel"
            class="text-[11px] uppercase tracking-wider font-bold mb-1.5 text-slate-400"
          >
            In
          </p>
          <p id="statCountdown" class="text-[14px] font-bold text-emerald-600">
            —
          </p>
        </div>
      </div>

      <!-- Body -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        <!-- Left (2/3) -->
        <div class="lg:col-span-2 space-y-6">
          <!-- Questions & Answers -->
          <div
            class="bg-white rounded-2xl p-6 sm:p-7 border border-slate-200 shadow-sm"
          >
            <div class="flex items-center justify-between mb-6">
              <h2 class="font-serif text-[20px] text-slate-800">Questions</h2>
              <span
                id="questionsCount"
                class="text-[11px] text-slate-400 bg-slate-100 px-2.5 py-1 rounded-full font-medium"
              >
                0 questions
              </span>
            </div>

            <div id="questionsList" class="space-y-5"></div>

            <div
              id="questionsEmpty"
              class="hidden flex-col items-center justify-center py-10 text-center"
            >
              <div
                class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center mb-3"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#94a3b8"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                  <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
              </div>
              <p class="text-[13px] font-medium text-slate-500 mb-0.5">
                No questions
              </p>
              <p class="text-[12px] text-slate-400">
                This meeting has no preparation questions
              </p>
            </div>

            <!-- Save bar -->
            <div
              id="saveAnswersBar"
              class="hidden mt-6 pt-5 border-t border-slate-100 items-center justify-between gap-3"
            >
              <p class="text-[12px] text-slate-400">Unsaved changes</p>
              <button
                id="btnSaveAnswers"
                class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 text-white text-[13px] font-medium rounded-lg hover:bg-slate-900 transition-all hover:-translate-y-px hover:shadow-md active:translate-y-0"
              >
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Save answers
              </button>
            </div>
          </div>

          <!-- Post-meeting notes -->
          <div
            class="bg-white rounded-2xl p-6 sm:p-7 border border-slate-200 shadow-sm"
          >
            <h2 class="font-serif text-[20px] text-slate-800 mb-4">Notes</h2>
            <textarea
              id="meetingNotes"
              rows="5"
              placeholder="Summarize what was discussed, next steps, action items…"
              class="w-full text-[13.5px] text-slate-700 leading-relaxed placeholder:text-slate-300 resize-none outline-none border-0 bg-transparent focus:ring-0 p-0"
            >
            </textarea>
            <div
              class="mt-4 pt-4 border-t border-slate-100 flex items-center justify-between"
            >
              <p id="notesStatus" class="text-[11.5px] text-slate-400"></p>
              <button
                id="btnSaveNotes"
                class="flex items-center gap-1.5 px-4 py-2 bg-slate-800 text-white text-[13px] font-medium rounded-lg hover:bg-slate-900 transition-all hover:-translate-y-px hover:shadow-md active:translate-y-0 opacity-50 pointer-events-none"
              >
                <svg
                  width="13"
                  height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Save notes
              </button>
            </div>
          </div>
        </div>

        <!-- Right (1/3) -->
        <div class="space-y-5 sticky top-24">
          <!-- Change status -->
          <div
            class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm"
          >
            <h3 class="font-serif text-[18px] text-slate-800 mb-4">Status</h3>
            <div id="statusButtons" class="grid grid-cols-2 gap-2"></div>
          </div>

          <!-- Activity -->
          <div
            class="bg-white rounded-2xl p-6 border border-slate-200 shadow-sm"
          >
            <h3 class="font-serif text-[18px] text-slate-800 mb-5">Activity</h3>
            <div class="space-y-4">
              <div>
                <div class="flex items-center gap-1.5 mb-0.5">
                  <div class="w-2 h-2 rounded-full bg-emerald-400 shrink-0">
                  </div>
                  <p class="text-[13px] font-medium text-slate-700">Created</p>
                </div>
                <p
                  id="actCreatedAt"
                  class="text-[11.5px] text-slate-400 pl-3.5 font-medium"
                >
                  —
                </p>
              </div>
              <div>
                <div class="flex items-center gap-1.5 mb-0.5">
                  <div class="w-2 h-2 rounded-full bg-sky-400 shrink-0"></div>
                  <p class="text-[13px] font-medium text-slate-700">
                    Last updated
                  </p>
                </div>
                <p
                  id="actUpdatedAt"
                  class="text-[11.5px] text-slate-400 pl-3.5 font-medium"
                >
                  —
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete modal -->
  <div
    id="deleteMeetingOverlay"
    class="fixed inset-0 z-50 hidden items-center justify-center"
    style="background: rgba(15,23,42,0.35); backdrop-filter: blur(3px);"
  >
    <div
      id="deleteMeetingModal"
      class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden"
      style="transform: scale(0.95); opacity: 0; transition: transform 0.18s cubic-bezier(.34,1.56,.64,1), opacity 0.15s ease;"
    >
      <div class="h-1 w-full bg-linear-to-r from-red-400 to-red-500"></div>
      <div class="px-6 py-5">
        <div class="flex items-start gap-4">
          <div
            class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center shrink-0 mt-0.5"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#ef4444"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
              <path d="M10 11v6M14 11v6"></path>
              <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
            </svg>
          </div>
          <div>
            <p class="text-slate-800 font-semibold text-[15px]">
              Delete meeting?
            </p>
            <p class="text-slate-400 text-[13px] mt-1 leading-relaxed">
              This will permanently delete the meeting and all its answers.
              Cannot be undone.
            </p>
          </div>
        </div>
        <div class="flex items-center justify-end gap-2.5 mt-5">
          <button
            id="deleteMeetingCancel"
            class="px-4 py-2 text-[13px] font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors"
          >
            Cancel
          </button>
          <button
            id="deleteMeetingConfirm"
            class="px-4 py-2 text-[13px] font-medium text-white bg-red-500 hover:bg-red-600 rounded-lg transition-colors"
          >
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import '../../../scripts/meetings/meetingsDetail'
</script>
