---

---

<section
  class="flex-1 flex items-center justify-center p-6 lg:p-12 relative bg-[#faf7f0] overflow-hidden"
>
  <!-- Blobs -->
  <div
    class="absolute -top-20 -right-16 w-75 h-75 rounded-full pointer-events-none"
    style="background:radial-gradient(ellipse, rgba(107,145,119,0.08) 0%, transparent 70%);"
  >
  </div>
  <div
    class="absolute -bottom-24 -left-20 w-87.5 h-87.5 rounded-full pointer-events-none"
    style="background:radial-gradient(ellipse, rgba(130,160,200,0.07) 0%, transparent 70%);"
  >
  </div>

  <div class="w-full max-w-105 relative z-10 py-8">
    <!-- Card -->
    <div
      class="bg-white rounded-2xl p-8 lg:p-9 shadow-[0_0_0_1px_rgba(180,195,210,0.3),0_4px_6px_-1px_rgba(100,120,140,0.06),0_20px_50px_-10px_rgba(80,100,130,0.12)]"
    >
      <!-- Mobile logo -->
      <div
        class="h-auto w-3/12 rounded-[9px] overflow-hidden shrink-0 flex items-center justify-center lg:hidden"
      >
        <img
          src="/logo.png"
          alt="Veldra logo"
          class="w-full h-full object-contain brightness-0"
          loading="eager"
        />
      </div>

      <!-- Header -->
      <div class="mb-7 anim-1">
        <h2 class="font-serif text-[26px] text-slate-800 tracking-tight mb-1.5">
          Iniciá sesión
        </h2>
        <p class="text-[14px] text-slate-400">
          ¿No tenés cuenta?
          <a
            href="/register"
            class="text-[#6b9177] font-medium border-b border-[rgba(107,145,119,0.4)] pb-px hover:border-[#6b9177] transition-colors"
          >
            Registrate gratis
          </a>
        </p>
      </div>

      <!-- Google button -->
      <div class="anim-2">
        <button
          id="btnGoogle"
          type="button"
          class="w-full flex items-center justify-center gap-2.5 bg-[#fdfcf8] text-slate-700 border border-[#dde6f0] rounded-[10px] px-5 py-3 text-[14.5px] font-medium cursor-pointer transition-all duration-200 hover:bg-white hover:border-[#c8d8e8] hover:-translate-y-px hover:shadow-[0_4px_14px_rgba(100,120,140,0.1)] active:translate-y-0"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              fill="#4285F4"></path>
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"></path>
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              fill="#FBBC05"></path>
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"></path>
          </svg>
          Continuar con Google
        </button>
      </div>

      <!-- Divider -->
      <div class="flex items-center gap-3 my-5 anim-3">
        <div
          class="flex-1 h-px bg-linear-to-r from-transparent via-[#dde6f0] to-transparent"
        >
        </div>
        <span class="text-[12.5px] text-slate-400 font-medium whitespace-nowrap"
          >o iniciá con email</span
        >
        <div
          class="flex-1 h-px bg-linear-to-r from-transparent via-[#dde6f0] to-transparent"
        >
        </div>
      </div>

      <!-- Form -->
      <form id="loginForm" novalidate class="flex flex-col gap-4">
        <!-- Email -->
        <div class="anim-3">
          <label
            for="email"
            class="block text-[13px] font-medium text-slate-600 mb-1.5"
          >
            Correo electrónico
          </label>
          <div class="relative">
            <span
              class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#94a3b8"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <input
              id="email"
              type="email"
              autocomplete="email"
              placeholder="tu@correo.com"
              class="input-field pl-10!"
            />
          </div>
          <p id="emailError" class="hidden text-[12px] text-red-400 mt-1.5"></p>
        </div>

        <!-- Password -->
        <div class="anim-4">
          <div class="flex items-center justify-between mb-1.5">
            <label
              for="password"
              class="block text-[13px] font-medium text-slate-600"
            >
              Contraseña
            </label>
            <a
              href="/forgot-password"
              class="text-[12px] text-[#6b9177] hover:text-[#537860] transition-colors border-b border-transparent hover:border-[rgba(107,145,119,0.4)]"
            >
              ¿Olvidaste tu contraseña?
            </a>
          </div>
          <div class="relative">
            <span
              class="absolute left-3.5 top-1/2 -translate-y-1/2 pointer-events-none"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#94a3b8"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
            </span>
            <input
              id="password"
              type="password"
              autocomplete="current-password"
              placeholder="Tu contraseña"
              class="input-field pl-10! pr-11!"
            />
            <button
              id="togglePassword"
              type="button"
              aria-label="Mostrar contraseña"
              class="absolute right-3 top-1/2 -translate-y-1/2 p-0.5 text-slate-400 hover:text-slate-600 transition-colors"
            >
              <svg
                id="eyeIcon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
          <p id="passwordError" class="hidden text-[12px] text-red-400 mt-1.5">
          </p>
        </div>

        <div
          id="authError"
          class="hidden anim-fade items-center gap-2.5 bg-red-50 border border-red-100 rounded-xl px-4 py-3"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#f87171"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <p class="text-[12.5px] text-red-500">
            Email o contraseña incorrectos. Intentá de nuevo.
          </p>
        </div>

        <!-- Submit -->
        <div class="anim-5 mt-1">
          <button
            id="btnSubmit"
            type="submit"
            class="w-full flex items-center justify-center gap-2 bg-slate-800 text-[#fdfcf8] rounded-[10px] px-5 py-3.5 text-[14.5px] font-semibold tracking-wide cursor-pointer transition-all duration-200 hover:bg-slate-900 hover:-translate-y-px hover:shadow-[0_6px_20px_rgba(30,41,59,0.25)] active:translate-y-0"
          >
            <span id="btnLabel">Iniciar sesión</span>
            <svg
              id="btnArrow"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
            <svg
              id="btnSpinner"
              class="hidden animate-spin"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
            >
              <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
            </svg>
          </button>
        </div>
      </form>
    </div>

    <p class="text-center text-[12px] text-slate-400 mt-5 anim-5">
      ¿Problemas para ingresar?
      <a
        href="mailto:ezequielrodrigosaucedo@gmail.com"
        class="text-[#6b9177] hover:text-[#537860] transition-colors"
        >Contactá soporte</a
      >
    </p>
  </div>
</section>

<style>
  body {
    font-family: 'DM Sans', sans-serif;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .anim-1 {
    animation: fadeUp 0.55s ease 0.05s both;
  }
  .anim-2 {
    animation: fadeUp 0.55s ease 0.12s both;
  }
  .anim-3 {
    animation: fadeUp 0.55s ease 0.19s both;
  }
  .anim-4 {
    animation: fadeUp 0.55s ease 0.26s both;
  }
  .anim-5 {
    animation: fadeUp 0.55s ease 0.33s both;
  }
  .anim-fade {
    animation: fadeIn 0.3s ease both;
  }
</style>

<script>
  import { fetchAPI } from '../../../lib/fetchApi'
  import { showAlert } from '../../../lib/showAlert'
  import { parseAuthError } from '../../../lib/authErrorMessages'

  const params = new URLSearchParams(window.location.search)
  if (params.get('t') === 'account_created') {
    showAlert({
      message: 'Cuenta creada correctamente',
      description:
        'Te enviamos un correo de verificación. Revisa tu bandeja de entrada antes de iniciar sesión.',
      duration: 5000,
    })
  }

  const passwordInput = document.getElementById('password') as HTMLInputElement
  const toggleBtn = document.getElementById(
    'togglePassword'
  ) as HTMLInputElement
  const eyeIcon = document.getElementById('eyeIcon') as HTMLInputElement

  const eyeOpen = `
    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
    <circle cx="12" cy="12" r="3"/>
  `
  const eyeClosed = `
    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
    <line x1="1" y1="1" x2="23" y2="23"/>
  `

  toggleBtn.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password'
    passwordInput.type = isPassword ? 'text' : 'password'
    eyeIcon.innerHTML = isPassword ? eyeClosed : eyeOpen
    toggleBtn.setAttribute(
      'aria-label',
      isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña'
    )
  })

  const emailInput = document.getElementById('email') as HTMLInputElement
  const emailError = document.getElementById('emailError') as HTMLElement
  const passwordError = document.getElementById('passwordError') as HTMLElement
  const authError = document.getElementById('authError') as HTMLElement

  function clearFieldError(input: HTMLElement, errorEl: HTMLElement) {
    input.addEventListener('input', () => {
      input.classList.remove('error')
      errorEl.classList.add('hidden')
      authError?.classList.add('hidden')
      authError?.classList.remove('flex')
    })
  }

  clearFieldError(emailInput, emailError)
  clearFieldError(passwordInput, passwordError)

  const form = document.getElementById('loginForm') as HTMLFormElement
  const btnSubmit = document.getElementById('btnSubmit') as HTMLButtonElement
  const btnLabel = document.getElementById('btnLabel') as HTMLLabelElement
  const btnArrow = document.getElementById('btnArrow') as HTMLButtonElement
  const btnSpinner = document.getElementById('btnSpinner') as HTMLButtonElement

  function validateEmail(value: string) {
    return /\S+@\S+\.\S+/.test(value)
  }

  function setLoading(loading: boolean) {
    btnSubmit.disabled = loading
    btnLabel.textContent = loading ? 'Ingresando...' : 'Iniciar sesión'
    btnArrow.classList.toggle('hidden', loading)
    btnSpinner.classList.toggle('hidden', !loading)
  }

  function showAuthError() {
    authError.classList.remove('hidden')
    authError.classList.add('flex')
    const card = form.closest('.bg-white') as HTMLDivElement
    card.style.transition = 'transform 0.1s ease'
    card.style.transform = 'translateX(-4px)'
    setTimeout(() => {
      card.style.transform = 'translateX(4px)'
    }, 100)
    setTimeout(() => {
      card.style.transform = 'translateX(-2px)'
    }, 200)
    setTimeout(() => {
      card.style.transform = 'translateX(0)'
    }, 300)
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault()

    let valid = true

    if (!validateEmail(emailInput.value)) {
      emailInput.classList.add('error')
      emailError.classList.remove('hidden')
      emailError.textContent = 'Ingresá un correo válido'
      valid = false
    }

    if (!passwordInput.value.trim()) {
      passwordInput.classList.add('error')
      passwordError.classList.remove('hidden')
      passwordError.textContent = 'Ingresá tu contraseña'
      valid = false
    }

    if (!valid) return
    setLoading(true)

    try {
      const email = emailInput.value
      const password = passwordInput.value

      const res = await fetchAPI('/api/auth/login', 'POST', { email, password })

      if (!res.ok) {
        const errorData = await res.json()
        console.error(errorData)
      }

      const data = await res.json()

      if (data) {
        e.preventDefault()
        btnLabel.textContent = '✓ Entrando...'
        btnSubmit.style.background = '#6b9177'
        window.location.href = '/app/dashboard'
      }
    } catch (err: any) {
      showAuthError()

      if (err.message.includes('Email not confirmed')) {
        return showAlert({
          message: 'Debes verificar tu correo',
          description:
            'Si no lo ves, revisa la bandeja de spam o correo no deseados',
          type: 'ERROR',
        })
      }

      setLoading(false)
      showAlert({
        message: 'Error al iniciar sesión',
        description: parseAuthError(err?.code),
        type: 'ERROR',
      })
    }
  })

  // ── Google OAuth ─────────────────────────────────────────────────────────
  document.getElementById('btnGoogle')?.addEventListener('click', () => {
    // Conectar con tu provider — ej: supabase.auth.signInWithOAuth({ provider: 'google' })
    console.log('Google OAuth login')
  })
</script>
