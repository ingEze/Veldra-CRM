---
import '../../../styles/meetings/modal.css'
---

<div
  id="meetingModal"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
>
  <!-- Backdrop -->
  <div
    id="meetingModalBackdrop"
    class="absolute inset-0 bg-slate-900/40 backdrop-blur-[2px]"
  >
  </div>

  <!-- Panel -->
  <div
    id="meetingModalPanel"
    class="relative bg-[#fdfcf8] rounded-2xl shadow-2xl border border-[#eef2f7] w-full max-w-lg max-h-[90vh] flex flex-col overflow-hidden"
  >
    <!-- Header -->
    <div
      class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-[#eef2f7] shrink-0"
    >
      <div>
        <h2 class="font-serif text-[20px] text-slate-800 leading-tight">
          Schedule meeting
        </h2>
        <p class="text-[12px] text-slate-400 mt-0.5">
          Fill in the details for your upcoming meeting
        </p>
      </div>
      <button
        id="closeMeetingModal"
        class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Form -->
    <form
      id="meetingForm"
      class="overflow-y-auto flex-1 px-6 py-6 flex flex-col gap-6"
      novalidate
    >
      <!-- Title -->
      <div class="flex flex-col gap-2">
        <label for="meetingTitle" class="field-label">
          Title <span class="text-red-400">*</span>
        </label>
        <input
          id="meetingTitle"
          type="text"
          class="input-field"
          placeholder="e.g. Discovery call with Sarah"
          maxlength="100"
        />
      </div>

      <!-- Date & Time (optional) -->
      <div class="flex flex-col gap-2">
        <label for="meetingDate" class="field-label"> Date & Time </label>
        <input id="meetingDate" type="datetime-local" class="input-field" />
      </div>

      <!-- Row: Type + Status -->
      <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label for="meetingType" class="field-label">
            Type <span class="text-red-400">*</span>
          </label>
          <div class="select-wrapper">
            <select id="meetingType" class="input-field select-field">
              <option value="">Select type</option>
              <option value="phone_call">Phone call</option>
              <option value="video_call">Video call</option>
              <option value="in_person">In person</option>
              <option value="chat">Chat</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="meetingStatus" class="field-label">Status</label>
          <div class="select-wrapper">
            <select id="meetingStatus" class="input-field select-field">
              <option value="scheduled">Scheduled</option>
              <option value="completed">Completed</option>
              <option value="cancelled">Cancelled</option>
              <option value="rescheduled">Rescheduled</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Client -->
      <div class="flex flex-col gap-2">
        <label for="meetingClientId" class="field-label">
          Client <span class="text-red-400">*</span>
        </label>

        <div class="select-wrapper">
          <select
            id="meetingClientId"
            class="input-field select-field w-full"
            required
          >
            <option value="">No client linked</option>
          </select>
        </div>
      </div>

      <!-- Questions (max 5) -->
      <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between">
          <label class="field-label">
            Preparation questions
            <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <span
            id="questionsCount"
            class="text-[11px] font-semibold text-slate-400">0 / 5</span
          >
        </div>
        <p class="text-[12px] text-slate-400 -mt-1.5 leading-relaxed">
          Add up to 5 questions to answer during or after the meeting.
        </p>

        <div id="questionsList" class="flex flex-col gap-2.5"></div>

        <button id="addQuestionBtn" type="button" class="add-question-btn">
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Add question
        </button>

        <div
          id="questionsLimitNotice"
          class="hidden items-center gap-2 text-[12px] text-amber-600 bg-amber-50 border border-amber-200 rounded-lg px-3.5 py-2.5"
        >
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          Free plan limit reached — maximum 5 questions per meeting.
        </div>
      </div>
    </form>

    <!-- Footer — inside panel, outside form -->
    <div
      class="px-6 py-4 border-t border-[#eef2f7] flex items-center justify-between gap-3 shrink-0 bg-white/60"
    >
      <button
        id="cancelMeetingModal"
        type="button"
        class="text-[13px] text-slate-500 font-medium hover:text-slate-700 transition-colors px-3 py-2 rounded-lg hover:bg-slate-100"
      >
        Cancel
      </button>
      <button
        id="saveMeetingBtn"
        type="submit"
        form="meetingForm"
        class="flex items-center gap-2 bg-slate-800 text-[#fdfcf8] text-[13px] font-medium px-5 py-2.5 rounded-lg transition-all duration-200 hover:bg-slate-900 hover:-translate-y-px hover:shadow-md active:translate-y-0 disabled:opacity-50 disabled:pointer-events-none"
      >
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"
          ></path>
          <polyline points="17 21 17 13 7 13 7 21"></polyline>
          <polyline points="7 3 7 8 15 8"></polyline>
        </svg>
        Save meeting
      </button>
    </div>
  </div>
</div>

<script>
  import '../../../scripts/meetings/modal'
</script>
